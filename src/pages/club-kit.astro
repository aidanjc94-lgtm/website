---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
---
<BaseLayout title="Club Kit">
  <Hero eyebrow="Club kit" title="Wear the Fenland colours." text="Club kit information should be simple for members to find and easy for the committee to update when suppliers, prices or ordering windows change." primaryHref="/contact/" primaryLabel="Ask about kit" secondaryHref="/welfare-policies/" secondaryLabel="Code of conduct" />
  <section class="section section--white"><div class="container grid grid--2"><div class="prose"><h2>Kit information</h2><p class="callout"><strong>TODO:</strong> confirm the current club kit supplier, ordering process, prices, size guide, payment method and delivery/collection arrangements.</p><p>The new website should keep this page practical: what members can buy, how to order it, and who to contact if they have questions.</p></div><div class="card"><h3>First-claim colours</h3><p>The Fenland 10 race information reminds affiliated runners to run in their first-claim club colours. Add any club-specific guidance here once confirmed.</p></div></div></section>
</BaseLayout>
